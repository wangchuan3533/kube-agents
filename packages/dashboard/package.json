{
  "name": "@kube-agents/dashboard",
  "version": "0.1.0",
  "description": "Web dashboard for inspecting kube-agents status",
  "type": "module",
  "main": "./dist/server/index.js",
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "vite build && tsup",
    "build:client": "vite build",
    "build:server": "tsup",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@kubernetes/client-node": "^1.0.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "postcss": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0"
  }
}
