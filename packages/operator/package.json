{
  "name": "@kube-agents/operator",
  "version": "0.1.0",
  "description": "Kubernetes operator for kube-agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
